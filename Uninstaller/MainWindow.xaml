<Window x:Class="SCNativeUninstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SC Native — Удаление" Height="480" Width="560"
        WindowStyle="None"
        Background="#0D0D0D"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/app_icon.png">

    <Border CornerRadius="12" Background="#0D0D0D" BorderBrush="#222222" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" Background="#111111"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Height="42">
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Resources/app_icon.png"
                               Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="SC Native" FontSize="14" Foreground="#E0E0E0"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Удаление" FontSize="12" Foreground="#666666"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="CloseButton" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="40" Height="42" Click="CloseButton_Click" Cursor="Hand"
                            BorderThickness="0" Background="Transparent">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="0,12,0,0">
                                    <TextBlock Text="✕" Foreground="#888888" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                        <Setter TargetName="Bd" Property="TextBlock.Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,20,24,0">
                <!-- Step 1: Feedback -->
                <StackPanel x:Name="FeedbackPanel" Visibility="Visible">
                    <TextBlock Text="Жаль, что вы уходите" Foreground="White" FontSize="20" FontWeight="Bold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Подскажите, почему удаляете SC Native?" Foreground="#99FFFFFF" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Причины -->
                    <StackPanel x:Name="ReasonsPanel" Margin="0,0,0,12">
                        <RadioButton x:Name="ReasonBugs" Content="Баги и ошибки" Foreground="#CCFFFFFF" FontSize="12"
                                     Margin="0,4" Cursor="Hand" GroupName="Reason"/>
                        <RadioButton x:Name="ReasonMissing" Content="Не хватает функций" Foreground="#CCFFFFFF" FontSize="12"
                                     Margin="0,4" Cursor="Hand" GroupName="Reason"/>
                        <RadioButton x:Name="ReasonAnother" Content="Нашёл другую программу" Foreground="#CCFFFFFF" FontSize="12"
                                     Margin="0,4" Cursor="Hand" GroupName="Reason"/>
                        <RadioButton x:Name="ReasonTemp" Content="Временно не нужна" Foreground="#CCFFFFFF" FontSize="12"
                                     Margin="0,4" Cursor="Hand" GroupName="Reason"/>
                        <RadioButton x:Name="ReasonOther" Content="Другое" Foreground="#CCFFFFFF" FontSize="12"
                                     Margin="0,4" Cursor="Hand" GroupName="Reason"/>
                    </StackPanel>

                    <!-- Свой комментарий -->
                    <TextBlock Text="Комментарий (необязательно):" Foreground="#66FFFFFF" FontSize="10"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="CommentBox" Background="#15FFFFFF" Foreground="#DDFFFFFF"
                             BorderThickness="1" BorderBrush="#25FFFFFF" Padding="10,8"
                             FontSize="12" Margin="0,0,0,8" MaxLength="500"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="70"
                             SelectionBrush="#CC7B3A" CaretBrush="#CC7B3A" VerticalScrollBarVisibility="Auto"/>

                    <!-- Удаление данных -->
                    <CheckBox x:Name="DeleteDataCheck" IsChecked="False" Margin="0,8,0,0" Cursor="Hand">
                        <CheckBox.Template>
                            <ControlTemplate TargetType="CheckBox">
                                <StackPanel Orientation="Horizontal" Cursor="Hand">
                                    <Border x:Name="Box" Width="18" Height="18" CornerRadius="4"
                                            Background="#15FFFFFF" BorderBrush="#44FFFFFF" BorderThickness="1"
                                            Margin="0,0,8,0">
                                        <TextBlock x:Name="Mark" Text="✓" Foreground="#CC7B3A" FontSize="12"
                                                   FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                    </Border>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="Удалить данные приложения" Foreground="#CCFFFFFF" FontSize="12"/>
                                        <LineBreak/>
                                        <Run Text="(лайки, плейлисты, настройки)" Foreground="#66FFFFFF" FontSize="10"/>
                                    </TextBlock>
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Mark" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="Box" Property="Background" Value="#25CC7B3A"/>
                                        <Setter TargetName="Box" Property="BorderBrush" Value="#CC7B3A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </CheckBox.Template>
                    </CheckBox>
                </StackPanel>

                <!-- Step 2: Progress -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed">
                    <TextBlock Text="Удаление..." Foreground="White" FontSize="20" FontWeight="Bold"
                               Margin="0,0,0,20"/>
                    <ProgressBar x:Name="UninstallProgress" Height="6" Background="#20FFFFFF"
                                 Foreground="#CC7B3A" Value="0" Margin="0,0,0,10"/>
                    <TextBlock x:Name="ProgressStatus" Text="Подготовка..." Foreground="#99FFFFFF" FontSize="11"/>
                </StackPanel>

                <!-- Step 3: Done -->
                <StackPanel x:Name="DonePanel" Visibility="Collapsed" VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="SC Native удалён" Foreground="White" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Спасибо за обратную связь!" Foreground="#99FFFFFF" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock x:Name="FeedbackError" Text="" Foreground="#66FFFFFF" FontSize="10"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                </StackPanel>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#0A0A0A" CornerRadius="0,0,12,12" Padding="24,12">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock x:Name="FooterText" Text="Шаг 1 из 2" Foreground="#44FFFFFF" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelButton" Content="Отмена" Click="CancelButton_Click"
                                Background="#15FFFFFF" Foreground="#99FFFFFF" BorderThickness="0"
                                Padding="14,6" FontSize="12" Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="14,6">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="UninstallButton" Content="Удалить" Click="UninstallButton_Click"
                                Background="#CC3333" Foreground="White" BorderThickness="0"
                                Padding="14,6" FontSize="12" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="14,6">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#DD4444"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="CloseDoneButton" Content="Закрыть" Click="CloseDoneButton_Click"
                                Background="#CC7B3A" Foreground="White" BorderThickness="0"
                                Padding="14,6" FontSize="12" FontWeight="SemiBold" Cursor="Hand" Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="14,6">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#DD8F4E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
