<Window x:Class="SoundCloudClient.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Вход в SoundCloud" Height="460" Width="480"
        WindowStyle="None"
        Background="#0D0D0D"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/app_icon.png">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0" CornerRadius="12" ResizeBorderThickness="4"
                            CaptionHeight="0" NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>

    <Border ClipToBounds="True" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="#08FFFFFF">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                            VerticalAlignment="Center" Margin="15,0">
                    <Image Source="pack://application:,,,/Resources/app_icon.png"
                           Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Вход в SoundCloud" Foreground="#CCFFFFFF" FontWeight="SemiBold"
                               VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="36" Height="36" Margin="0,0,6,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#FFAA88" FontSize="13"
                        Click="Cancel_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Контент -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,12,24,24">
                    <!-- Описание -->
                    <TextBlock Text="Для доступа к плейлистам и лайкам нужен OAuth-токен."
                               Foreground="#99FFFFFF" FontSize="12" TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <!-- Инструкция -->
                    <TextBlock Text="КАК ПОЛУЧИТЬ ТОКЕН" Foreground="#44FFFFFF" FontSize="10"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <TextBlock Foreground="#99FFFFFF" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="20">
                        <Run Text="1. Открой soundcloud.com в браузере"/>
                        <LineBreak/>
                        <Run Text="2. Войди в свой аккаунт"/>
                        <LineBreak/>
                        <Run Text="3. Открой DevTools (F12)"/>
                        <LineBreak/>
                        <Run Text="4. Вкладка Network → найди запрос к api-v2.soundcloud.com"/>
                        <LineBreak/>
                        <Run Text="5. Скопируй значение oauth_token из URL"/>
                    </TextBlock>

                    <!-- Поле ввода -->
                    <TextBlock Text="OAUTH TOKEN" Foreground="#44FFFFFF" FontSize="10"
                               FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Border Background="#12FFFFFF" CornerRadius="8" Margin="0,0,0,20">
                        <TextBox x:Name="TokenBox" Background="Transparent" Foreground="White"
                                 BorderThickness="0" Padding="12,10" FontSize="13"
                                 CaretBrush="#CC7B3A"/>
                    </Border>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Войти" Width="130" Height="38" Margin="0,0,10,0"
                                Background="#CC7B3A" Foreground="White" BorderThickness="0"
                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                Click="Login_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="20,10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#DD8F4E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="Отмена" Width="130" Height="38"
                                Background="#20FFFFFF" Foreground="White" BorderThickness="0"
                                FontSize="13" Cursor="Hand"
                                Click="Cancel_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="20,10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
