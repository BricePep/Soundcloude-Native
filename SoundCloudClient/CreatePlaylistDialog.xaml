<Window x:Class="SoundCloudClient.CreatePlaylistDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Новый плейлист" Height="200" Width="360"
        WindowStyle="None"
        Background="#0D0D0D"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/app_icon.png">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0" CornerRadius="12" ResizeBorderThickness="4"
                            CaptionHeight="0" NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>

    <Border ClipToBounds="True" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="#08FFFFFF">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                            VerticalAlignment="Center" Margin="15,0">
                    <Image Source="pack://application:,,,/Resources/app_icon.png"
                           Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Новый плейлист" Foreground="#CCFFFFFF" FontWeight="SemiBold"
                               VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="36" Height="36" Margin="0,0,6,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#FFAA88" FontSize="13"
                        Click="Close_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Контент -->
            <StackPanel Grid.Row="1" Margin="24,12,24,24">
                <TextBlock Text="НАЗВАНИЕ ПЛЕЙЛИСТА" Foreground="#44FFFFFF" FontSize="10"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border Background="#12FFFFFF" CornerRadius="8" Margin="0,0,0,16">
                    <TextBox x:Name="PlaylistNameBox" Background="Transparent" Foreground="White"
                             BorderThickness="0" Padding="12,10" FontSize="13"
                             CaretBrush="#CC7B3A"/>
                </Border>

                <Button Content="Создать" Background="#CC7B3A" Foreground="White"
                        BorderThickness="0" Padding="15,8" FontSize="13" FontWeight="SemiBold"
                        Click="Create_Click" Cursor="Hand" HorizontalAlignment="Right">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="15,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#DD8F4E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
