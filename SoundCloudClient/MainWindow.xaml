                                            <VisualBrush Stretch="Fill">
                                                <VisualBrush.Visual>
                                                    <Border Background="White" CornerRadius="14" Width="220" Height="220"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Border.OpacityMask>
                                        <Grid>
                                            <TextBlock x:Name="LyricsArtworkPlaceholder" Text="♪" FontSize="48" Foreground="#33FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Image x:Name="LyricsArtwork" Stretch="UniformToFill"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <TextBlock x:Name="LyricsTitle" Foreground="White" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,16,0,4" TextAlignment="Center"/>
                                <TextBlock x:Name="LyricsArtist" Foreground="#77FFFFFF" FontSize="12" TextAlignment="Center" Margin="0,0,0,16"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <Button x:Name="LyricsPrevBtn" Style="{StaticResource PlayerIconBtn}" Click="PrevButton_Click">
                                        <materialDesign:PackIcon Kind="SkipPrevious" Width="18" Height="18" Foreground="#AAFFFFFF"/>
                                    </Button>
                                    <Button x:Name="LyricsPlayBtn" Width="42" Height="42" Background="{DynamicResource AccentBrush}" BorderThickness="0" Click="PlayPauseButton_Click" Cursor="Hand" Margin="10,0">
