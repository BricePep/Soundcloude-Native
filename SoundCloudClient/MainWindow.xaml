<Window x:Class="SoundCloudClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:SoundCloudClient"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="SC Native" Height="720" Width="1180"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI"
        Icon="pack://application:,,,/Resources/app_icon.png">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo>
            <TaskbarItemInfo.ThumbButtonInfos>
                <ThumbButtonInfoCollection>
                    <ThumbButtonInfo x:Name="TaskbarPrev" Description="Предыдущий трек"
                                     Command="{x:Static local:MainWindow.TaskbarPrevCommand}"/>
                    <ThumbButtonInfo x:Name="TaskbarPlayPause" Description="Пауза"
                                     Command="{x:Static local:MainWindow.TaskbarPlayPauseCommand}"/>
                    <ThumbButtonInfo x:Name="TaskbarNext" Description="Следующий трек"
                                     Command="{x:Static local:MainWindow.TaskbarNextCommand}"/>
                </ThumbButtonInfoCollection>
            </TaskbarItemInfo.ThumbButtonInfos>
        </TaskbarItemInfo>
    </Window.TaskbarItemInfo>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0" CornerRadius="10" ResizeBorderThickness="4"
                            CaptionHeight="0" NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepOrange" SecondaryColor="Orange"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <local:InvertBoolConverter x:Key="InvertBool"/>
            <local:SliderProgressWidthConverter x:Key="SliderProgressWidth"/>

            <!-- ═══ Акцент темы (динамически меняется при переключении темы) ═══ -->
            <Color x:Key="AccentColor">#FFFF7A00</Color>
            <Color x:Key="AccentLightColor">#FFFF9E2E</Color>
            <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>
            <SolidColorBrush x:Key="AccentLightBrush" Color="{DynamicResource AccentLightColor}"/>

            <!-- ═══ Тонкие скроллбары ═══ -->
            <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="Bd" CornerRadius="3" Background="#22FFFFFF" Margin="2,0"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#44FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#66FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="8"/>
                <Setter Property="MinWidth" Value="8"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="True" ViewportSize="{TemplateBinding ViewportSize}" Maximum="{TemplateBinding Maximum}" Minimum="{TemplateBinding Minimum}" Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollThumbStyle}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False"/>
                                    </Track.DecreaseRepeatButton>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Height" Value="8"/>
                                    <Setter Property="MinHeight" Value="8"/>
                                    <Setter Property="Width" Value="Auto"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ NavButton — кнопка навигации с PackIcon ═══ -->
            <Style x:Key="NavBtn" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="8,1"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform><ScaleTransform x:Name="NavScale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="Accent" Width="3" Height="20" CornerRadius="2" Background="{DynamicResource AccentBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-2,0,0,0" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform><ScaleTransform x:Name="AccentScale" ScaleY="0"/></Border.RenderTransform>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#0AFFFFFF"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="NavScale" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="NavScale" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.1"/>
                                        </Storyboard></BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="NavScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="NavScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard></BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="Tag" Value="Active">
                                    <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                    <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="AccentScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard></BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="AccentScale" Storyboard.TargetProperty="ScaleY" To="0" Duration="0:0:0.1"/>
                                        </Storyboard></BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ Слайдер прогресса ═══ -->
            <Style x:Key="ModernSlider" TargetType="Slider">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="MinHeight" Value="22"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid x:Name="SliderRoot" Height="22" VerticalAlignment="Center" SnapsToDevicePixels="True">
                                <!-- Серая фоновая полоса (на всю ширину) -->
                                <Border Height="3" Background="#22FFFFFF" CornerRadius="2" VerticalAlignment="Center" HorizontalAlignment="Stretch" SnapsToDevicePixels="True"/>
                                <!-- Цветная полоса прогресса (ширина по значению, акцентный цвет темы) -->
                                <Border Height="3" Background="{DynamicResource AccentBrush}" CornerRadius="2" VerticalAlignment="Center" HorizontalAlignment="Left" SnapsToDevicePixels="True">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource SliderProgressWidth}">
                                            <Binding RelativeSource="{RelativeSource AncestorType=Slider}" Path="Value"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=Slider}" Path="Maximum"/>
                                            <Binding ElementName="SliderRoot" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <!-- Track обрабатывает только перетаскивание thumb -->
                                <Track x:Name="PART_Track" VerticalAlignment="Center" Height="22">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge" Focusable="False" IsTabStop="False" OverridesDefaultStyle="True">
                                            <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent" Height="3" VerticalAlignment="Center"/></ControlTemplate></RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge" Focusable="False" IsTabStop="False" OverridesDefaultStyle="True">
                                            <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent" Height="3" VerticalAlignment="Center"/></ControlTemplate></RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="14" Height="14" VerticalAlignment="Center">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse Width="14" Height="14" Fill="White" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="5" ShadowDepth="0" Opacity="0.6" Color="Black"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ Вертикальный EQ-слайдер ═══ -->
            <Style x:Key="EqVerticalSlider" TargetType="Slider">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Orientation" Value="Vertical"/>
                <Setter Property="Minimum" Value="-12"/>
                <Setter Property="Maximum" Value="12"/>
                <Setter Property="IsMoveToPointEnabled" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid Width="34" SnapsToDevicePixels="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Фоновый трек (тонкая вертикальная линия) -->
                                <Border Width="3" Background="#18FFFFFF" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
                                <!-- Линия нуля (0 dB) -->
                                <Border Width="11" Height="1" Background="#33FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <!-- Цветная часть трека (от нуля до thumb) -->
                                <Border x:Name="EqFillTrack" Width="3" Background="{DynamicResource AccentBrush}" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- Высота и позиция задаются через converter или code-behind -->
                                </Border>
                                <!-- Track для перетаскивания -->
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge" Focusable="False" IsTabStop="False" OverridesDefaultStyle="True">
                                            <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge" Focusable="False" IsTabStop="False" OverridesDefaultStyle="True">
                                            <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="14" Height="14">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Grid>
                                                        <Ellipse x:Name="ThumbGlow" Width="22" Height="22" Fill="{DynamicResource AccentBrush}" Opacity="0.2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <Ellipse Width="10" Height="10" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Ellipse.Effect>
                                                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                                                            </Ellipse.Effect>
                                                        </Ellipse>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ThumbGlow" Property="Opacity" Value="0.4"/>
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbGlow" Property="Opacity" Value="0.55"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ Иконочная кнопка плеера ═══ -->
            <Style x:Key="PlayerIconBtn" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="16" Width="32" Height="32" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform><ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleX" To="1.12" Duration="0:0:0.1">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleY" To="1.12" Duration="0:0:0.1">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard></BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.15"/>
                                        </Storyboard></BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ Кнопка titlebar ═══ -->
            <Style x:Key="TitleBtn" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Width" Value="40"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="Foreground" Value="#99FFFFFF"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform><ScaleTransform x:Name="TitleScale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="TitleScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="TitleScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.08"/>
                                        </Storyboard></BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard><Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="TitleScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="TitleScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.1"/>
                                        </Storyboard></BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ Toggle switch (вкл/выкл) ═══ -->
            <Style x:Key="ToggleSwitch" TargetType="CheckBox">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Border x:Name="SwBg" Width="40" Height="22" CornerRadius="11" Background="#2A2A2A">
                                <Border x:Name="SwDot" Width="16" Height="16" CornerRadius="8" Background="#888888"
                                        Margin="3,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="SwBg" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="SwDot" Property="Background" Value="White"/>
                                    <Setter TargetName="SwDot" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="SwDot" Property="Margin" Value="0,0,3,0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="RootBorder" ClipToBounds="True" CornerRadius="10" BorderBrush="#1AFFFFFF" BorderThickness="1" Background="Transparent">
        <Grid>
            <!-- ═══ Фон ═══ -->
            <Image x:Name="BackgroundImage" Stretch="UniformToFill" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <Border x:Name="BackgroundDarken" Background="Black" Opacity="0"/>
            <Border x:Name="GradientOverlay">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop x:Name="GradStop1" Color="#CC0A0A0A" Offset="0"/>
                        <GradientStop x:Name="GradStop2" Color="#CC161623" Offset="0.5"/>
                        <GradientStop x:Name="GradStop3" Color="#CC0A0A0A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- ═══ Layout ═══ -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- ═══ TITLEBAR ═══ -->
                <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                            <Image Source="pack://application:,,,/Resources/app_icon.png" Width="14" Height="14" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="SC Native" Foreground="#88FFFFFF" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button Click="MinimizeButton_Click" Style="{StaticResource TitleBtn}" ToolTip="Свернуть">
                                <materialDesign:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                            </Button>
                            <Button x:Name="MaximizeButton" Click="MaximizeButton_Click" Style="{StaticResource TitleBtn}" ToolTip="Развернуть">
                                <Grid>
                                    <materialDesign:PackIcon x:Name="MaximizeIcon" Kind="WindowMaximize" Width="14" Height="14"/>
                                    <materialDesign:PackIcon x:Name="RestoreIcon" Kind="WindowRestore" Width="14" Height="14" Visibility="Collapsed"/>
                                </Grid>
                            </Button>
                            <Button Click="CloseButton_Click" Style="{StaticResource TitleBtn}" ToolTip="Закрыть">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent">
                                            <materialDesign:PackIcon x:Name="CloseIco" Kind="WindowClose" Width="14" Height="14" Foreground="#99FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                                <Setter TargetName="CloseIco" Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Grid>

                <!-- ═══ MAIN AREA ═══ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SidebarColumn" Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ═══ SIDEBAR ═══ -->
                    <Border x:Name="SidebarBorder" Grid.Column="0" Width="220" Background="#D8080808">
                        <Grid x:Name="SidebarContent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Профиль -->
                            <Grid x:Name="ProfileGrid" Grid.Row="0" Margin="14,18,14,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AvatarBorder" Grid.Column="0" Width="38" Height="38" CornerRadius="19"
                                        ClipToBounds="True" Background="#0AFFFFFF">
                                    <Border.OpacityMask>
                                        <VisualBrush Stretch="Fill">
                                            <VisualBrush.Visual>
                                                <Border Background="White" CornerRadius="19" Width="38" Height="38"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Border.OpacityMask>
                                    <Grid>
                                        <TextBlock x:Name="UserAvatarEmoji" Text="♪" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                                        <Image x:Name="UserAvatarImage" Stretch="UniformToFill" Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,8,0">
                                    <TextBlock x:Name="UserDisplayName" Text="SC Native" Foreground="White" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="UserNameText" Text="" Foreground="#66FFFFFF" FontSize="10" Visibility="Collapsed"/>
                                </StackPanel>
                                <Button x:Name="ToggleSidebarButton" Grid.Column="2" Click="ToggleSidebar_Click"
                                        Width="22" Height="22" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        ToolTip="Свернуть" VerticalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="11" Width="22" Height="22">
                                                <materialDesign:PackIcon x:Name="ToggleIcon" Kind="ChevronLeft" Width="14" Height="14" Foreground="#88FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                                                    <Setter TargetName="ToggleIcon" Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Навигация -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock x:Name="MenuHeader" Text="МЕНЮ" Foreground="#55FFFFFF" FontSize="9" FontWeight="SemiBold" Margin="20,8,0,6"/>

                                    <Button x:Name="NavHome" Click="NavHome_Click" Style="{StaticResource NavBtn}">
                                        <Grid Margin="14,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Grid.Column="0" Kind="HomeOutline" Width="18" Height="18" Foreground="#BBFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Главная" Foreground="#DDFFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>

                                    <Button x:Name="NavSearch" Click="NavSearch_Click" Style="{StaticResource NavBtn}">
                                        <Grid Margin="14,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Grid.Column="0" Kind="Magnify" Width="18" Height="18" Foreground="#BBFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Поиск" Foreground="#DDFFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>

                                    <Button x:Name="NavLikes" Click="NavLikes_Click" Style="{StaticResource NavBtn}">
                                        <Grid Margin="14,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Grid.Column="0" Kind="HeartOutline" Width="18" Height="18" Foreground="#BBFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Лайки" Foreground="#DDFFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>

                                    <Button x:Name="NavLibrary" Click="NavLibrary_Click" Style="{StaticResource NavBtn}">
                                        <Grid Margin="14,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Grid.Column="0" Kind="LibraryMusicOutline" Width="18" Height="18" Foreground="#BBFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Библиотека" Foreground="#DDFFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>

                                    <Rectangle x:Name="Sep1" Height="1" Margin="20,12,20,4" Fill="#15FFFFFF" Visibility="Collapsed"/>
                                    <TextBlock x:Name="AccountHeader" Text="АККАУНТ" Foreground="#55FFFFFF" FontSize="9" FontWeight="SemiBold" Margin="20,4,0,6" Visibility="Collapsed"/>

                                    <Rectangle x:Name="Sep2" Height="1" Margin="20,12,20,4" Fill="#10FFFFFF"/>

                                    <Button x:Name="NavSettings" Click="NavSettings_Click" Style="{StaticResource NavBtn}">
                                        <Grid Margin="14,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Grid.Column="0" Kind="CogOutline" Width="18" Height="18" Foreground="#BBFFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Настройки" Foreground="#DDFFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- ═══ Bug report + Предложка (внизу сайдбара) ═══ -->
                            <StackPanel Grid.Row="2" Margin="10,8,10,12">
                                <Border Padding="10,10" CornerRadius="10" Background="#0AFFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1" Margin="0,0,0,4">
                                    <StackPanel>
                                        <StackPanel x:Name="BugReportTextWrap" Orientation="Horizontal" Margin="0,0,0,8">
                                            <materialDesign:PackIcon Kind="BugOutline" Width="14" Height="14" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Top" Margin="0,1,6,0"/>
                                            <TextBlock x:Name="BugReportText" Text="Нашли баг? Сообщите о нём!" Foreground="#AAFFFFFF" FontSize="11" TextWrapping="Wrap" MaxWidth="170"/>
                                        </StackPanel>
                                        <Button x:Name="BugReportButton" Click="BugReportButton_Click" Cursor="Hand" BorderThickness="0" Foreground="White">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="7" Padding="8,7">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <materialDesign:PackIcon x:Name="BugReportIcon" Kind="Send" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <TextBlock x:Name="BugReportLabel" Text="Сообщить" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.6"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="SuggestSection" Padding="10,10" CornerRadius="10" Background="#0AFFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <materialDesign:PackIcon Kind="LightbulbOutline" Width="14" Height="14" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Top" Margin="0,1,6,0"/>
                                            <TextBlock Text="Есть идея? Предложи её!" Foreground="#AAFFFFFF" FontSize="11" TextWrapping="Wrap" MaxWidth="170"/>
                                        </StackPanel>
                                        <Button x:Name="SuggestButton" Click="SuggestButton_Click" Cursor="Hand" BorderThickness="0" Foreground="White">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="7" Padding="8,7">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <materialDesign:PackIcon Kind="RocketLaunchOutline" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <TextBlock Text="Предложить" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.6"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══ CONTENT ═══ -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header: приветствие + поиск -->
                        <Grid x:Name="ContentHeader" Grid.Row="0" Margin="24,16,24,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="320"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="GreetingText" Text="Добрый вечер" Foreground="White" FontSize="26" FontWeight="Bold"/>
                                <TextBlock x:Name="GreetingSub" Foreground="#66FFFFFF" FontSize="11" Margin="2,2,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="AddLocalMusicBtn" Click="AddLocalMusic_Click" Cursor="Hand" Visibility="Collapsed" VerticalAlignment="Center" Margin="0,0,8,0" BorderThickness="0" Foreground="White">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="10" Padding="12,7" BorderBrush="#22FFFFFF" BorderThickness="1" Background="#0EFFFFFF">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="22" Height="22" CornerRadius="6" Background="#1AFFFFFF" VerticalAlignment="Center" Margin="0,0,8,0">
                                                        <materialDesign:PackIcon Kind="FileMusicOutline" Width="14" Height="14" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="Добавить музыку" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#DDFFFFFF"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="CreatePlaylistTopBtn" Grid.Column="1" Click="CreatePlaylistButton_Click" Cursor="Hand" Visibility="Collapsed" VerticalAlignment="Center" Margin="0,0,12,0" BorderThickness="0" Foreground="White">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="10" Padding="12,7" BorderBrush="#22FFFFFF" BorderThickness="1" Background="#0EFFFFFF">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="22" Height="22" CornerRadius="6" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.3"/>
                                                    </Border.Effect>
                                                    <materialDesign:PackIcon Kind="PlaylistPlus" Width="14" Height="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="Новый плейлист" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#DDFFFFFF"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="Bd" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.2"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            </StackPanel>
                            <Border Grid.Column="2" Background="#0AFFFFFF" CornerRadius="20" Height="38" VerticalAlignment="Center" BorderBrush="#15FFFFFF" BorderThickness="1">
                                <Grid>
                                    <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" Foreground="#66FFFFFF" Margin="14,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SearchPlaceholder" Text="Поиск треков и артистов..." Foreground="#55FFFFFF" VerticalAlignment="Center" FontSize="12" Margin="38,0,14,0"/>
                                    <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="38,0,14,0" TextChanged="SearchBox_TextChanged" CaretBrush="White"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Track list -->
                        <ScrollViewer x:Name="TracksScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel" Margin="0,12,0,0">
                            <ListBox x:Name="TracksList" Background="Transparent" BorderThickness="0" Padding="16,4,16,12" SelectionChanged="TracksList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <!-- Трек -->
                                            <Grid x:Name="TrackRow" Height="56" Margin="8,1,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="56"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Обложка -->
                                                <Border Grid.Column="0" Width="46" Height="46" CornerRadius="8" ClipToBounds="True" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#0AFFFFFF" RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform><ScaleTransform x:Name="CoverScale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                                    <Border.OpacityMask>
                                                        <VisualBrush Stretch="Fill">
                                                            <VisualBrush.Visual>
                                                                <Border Background="White" CornerRadius="8" Width="46" Height="46"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Border.OpacityMask>
                                                    <Grid>
                                                        <Image Source="{Binding Artwork}" Stretch="UniformToFill"/>
                                                        <!-- Эквалайзер (когда играет) -->
                                                        <Border x:Name="PlayingIndicator" Background="#C0000000" Visibility="Collapsed" CornerRadius="6">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Border Width="3" Height="14" Background="{DynamicResource AccentBrush}" CornerRadius="1.5" Margin="1,0" RenderTransformOrigin="0.5,1">
                                                                    <Border.RenderTransform><ScaleTransform ScaleY="1"/></Border.RenderTransform>
                                                                    <Border.Triggers>
                                                                        <EventTrigger RoutedEvent="Loaded">
                                                                            <BeginStoryboard><Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.4" To="1" Duration="0:0:0.4"/>
                                                                            </Storyboard></BeginStoryboard>
                                                                        </EventTrigger>
                                                                    </Border.Triggers>
                                                                </Border>
                                                                <Border Width="3" Height="14" Background="{DynamicResource AccentBrush}" CornerRadius="1.5" Margin="1,0" RenderTransformOrigin="0.5,1">
                                                                    <Border.RenderTransform><ScaleTransform ScaleY="1"/></Border.RenderTransform>
                                                                    <Border.Triggers>
                                                                        <EventTrigger RoutedEvent="Loaded">
                                                                            <BeginStoryboard><Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.15">
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="0.3" Duration="0:0:0.5"/>
                                                                            </Storyboard></BeginStoryboard>
                                                                        </EventTrigger>
                                                                    </Border.Triggers>
                                                                </Border>
                                                                <Border Width="3" Height="14" Background="{DynamicResource AccentBrush}" CornerRadius="1.5" Margin="1,0" RenderTransformOrigin="0.5,1">
                                                                    <Border.RenderTransform><ScaleTransform ScaleY="1"/></Border.RenderTransform>
                                                                    <Border.Triggers>
                                                                        <EventTrigger RoutedEvent="Loaded">
                                                                            <BeginStoryboard><Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.3">
                                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.5" To="1" Duration="0:0:0.45"/>
                                                                            </Storyboard></BeginStoryboard>
                                                                        </EventTrigger>
                                                                    </Border.Triggers>
                                                                </Border>
                                                            </StackPanel>
                                                        </Border>
                                                        <!-- Пауза (когда на паузе) -->
                                                        <Border x:Name="PausedIndicator" Background="#C0000000" Visibility="Collapsed" CornerRadius="6">
                                                            <materialDesign:PackIcon Kind="Pause" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <!-- Название и артист -->
                                                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="12,0,8,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid Grid.Row="0" VerticalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Title}" Foreground="#FFFFFFFF" FontWeight="Medium" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                                                            <Button x:Name="HeartFull" Click="Heart_Click" Cursor="Hand" ToolTip="Убрать из лайков" Width="22" Height="22" Background="Transparent" BorderThickness="0" Visibility="Collapsed">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bd" Background="Transparent" Width="22" Height="22" RenderTransformOrigin="0.5,0.5">
                                                                            <Border.RenderTransform><ScaleTransform x:Name="HeartScaleFull" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                                                            <materialDesign:PackIcon Kind="Heart" Width="14" Height="14" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                            <Button x:Name="HeartEmpty" Click="Heart_Click" Cursor="Hand" ToolTip="Нравится" Width="22" Height="22" Background="Transparent" BorderThickness="0">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bd" Background="Transparent" Width="22" Height="22" RenderTransformOrigin="0.5,0.5">
                                                                            <Border.RenderTransform><ScaleTransform x:Name="HeartScaleEmpty" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                                                            <materialDesign:PackIcon Kind="HeartOutline" Width="14" Height="14" Foreground="#55FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                    <TextBlock Grid.Row="1" Text="{Binding ArtistName}" Foreground="#66FFFFFF" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                                <!-- Длительность + кнопки -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DurationFormatted}" Foreground="#55FFFFFF" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <Button Click="AddToPlaylistButton_Click" Cursor="Hand" ToolTip="В плейлист" Width="28" Height="28" Background="Transparent" BorderThickness="0">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                                                    <materialDesign:PackIcon x:Name="PlIcon" Kind="PlaylistPlus" Width="16" Height="16" Foreground="#55FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button x:Name="RemoveFromPlBtn" Click="RemoveFromPlaylist_Click" Cursor="Hand" ToolTip="Убрать из плейлиста" Width="28" Height="28" Background="Transparent" BorderThickness="0" Visibility="Collapsed">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                                                    <materialDesign:PackIcon Kind="PlaylistMinus" Width="16" Height="16" Foreground="#55FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/></Trigger></ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button Click="TrackMenuButton_Click" Cursor="Hand" ToolTip="Ещё" Width="28" Height="28" Background="Transparent" BorderThickness="0">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                                                    <materialDesign:PackIcon Kind="DotsVertical" Width="16" Height="16" Foreground="#55FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/></Trigger></ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Заголовок секции -->
                                            <StackPanel x:Name="SectionHeader" Orientation="Horizontal" Visibility="Collapsed" Margin="2,16,2,6">
                                                <Border Width="3" Height="14" CornerRadius="2" Background="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Title}" Foreground="#CCFFFFFF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                                                <Setter TargetName="TrackRow" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="SectionHeader" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsLiked}" Value="True">
                                                <Setter TargetName="HeartEmpty" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="HeartFull" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCurrentlyPlaying}" Value="True">
                                                <Setter TargetName="PlayingIndicator" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInPlaylist}" Value="True">
                                                <Setter TargetName="RemoveFromPlBtn" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCurrentlyPlaying}" Value="True"/>
                                                    <Condition Binding="{Binding IsPaused}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="PlayingIndicator" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="PausedIndicator" Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="IsHitTestVisible" Value="{Binding IsSectionHeader, Converter={StaticResource InvertBool}}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="6,2" RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform><ScaleTransform x:Name="ItemScale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#08FFFFFF"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard><Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="1.005" Duration="0:0:0.08"/>
                                                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="1.008" Duration="0:0:0.08"/>
                                                                </Storyboard></BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard><Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.1"/>
                                                                    <DoubleAnimation Storyboard.TargetName="ItemScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.1"/>
                                                                </Storyboard></BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#12FFFFFF"/></Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>

                        <!-- ═══ Lyrics Panel ═══ -->
                        <Grid x:Name="LyricsPanel" Grid.RowSpan="2" Visibility="Collapsed" Background="#E80A0A0A">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="32,0">
                                <Button x:Name="LyricsBackButton" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="LyricsBack_Click" Margin="0,0,0,24">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
