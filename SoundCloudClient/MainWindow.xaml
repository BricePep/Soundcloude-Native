                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="21">
                                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Path x:Name="LPlayIcon" Data="M6,4 L6,20 L20,12 Z" Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="2,0,0,0"/>
                                                        <StackPanel x:Name="LPauseIcon" Orientation="Horizontal" Visibility="Collapsed">
                                                            <Border Width="3" Height="12" Background="White" CornerRadius="1"/>
                                                            <Border Width="3" Height="12" Background="White" CornerRadius="1" Margin="3,0,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#FF8F1F"/></Trigger></ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="LyricsNextBtn" Style="{StaticResource PlayerIconBtn}" Click="NextButton_Click">
                                        <materialDesign:PackIcon Kind="SkipNext" Width="18" Height="18" Foreground="#AAFFFFFF"/>
                                    </Button>
                                </StackPanel>
                                <Slider x:Name="LyricsProgress" Minimum="0" Maximum="100" Value="0" Width="220" Style="{StaticResource ModernSlider}" IsMoveToPointEnabled="True" PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseDown" PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseUp"/>
                                <Grid Width="220" Margin="0,4,0,0">
                                    <TextBlock x:Name="LyricsCurrentTime" Text="0:00" Foreground="#55FFFFFF" FontSize="10" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="LyricsTotalTime" Text="0:00" Foreground="#55FFFFFF" FontSize="10" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                            <Border Grid.Column="1" Width="1" Background="#12FFFFFF" Margin="16,32"/>
                            <Grid Grid.Column="2" Margin="0,32,32,32">
                                <StackPanel x:Name="LyricsLoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="MusicNote" Width="36" Height="36" Foreground="#33FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <TextBlock Text="Загрузка текста..." Foreground="#55FFFFFF" FontSize="13" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel x:Name="LyricsNotFoundPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="MusicOff" Width="36" Height="36" Foreground="#33FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <TextBlock Text="Текст не найден" Foreground="#55FFFFFF" FontSize="13" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <ScrollViewer x:Name="LyricsSyncedScroll" VerticalScrollBarVisibility="Hidden" Visibility="Collapsed" Padding="20,0">
                                    <StackPanel x:Name="LyricsSyncedPanel"/>
                                </ScrollViewer>
                                <ScrollViewer x:Name="LyricsPlainScroll" VerticalScrollBarVisibility="Auto" Visibility="Collapsed" Padding="20,0">
                                    <TextBlock x:Name="LyricsPlainText" Foreground="#AAFFFFFF" FontSize="14" TextWrapping="Wrap" LineHeight="24"/>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <!-- ═══ Settings Panel ═══ -->
                        <ScrollViewer x:Name="SettingsPanel" Grid.RowSpan="2" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="36,24,36,28" Background="#E80A0A0A">
                            <StackPanel MaxWidth="760" HorizontalAlignment="Stretch">
                                <!-- ═══ Hero-заголовок с градиентом ═══ -->
                                <Border CornerRadius="16" Padding="24,22" Margin="0,0,0,18">
                                    <Border.Background>
                                        <LinearGradientBrush x:Name="SettingsHeroBrush" StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{StaticResource AccentLightColor}" Offset="0"/>
                                            <GradientStop Color="{StaticResource AccentColor}" Offset="0.6"/>
                                            <GradientStop Color="#0E0E0E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <Border x:Name="SettingsHeroIconBorder" Width="48" Height="48" CornerRadius="24" VerticalAlignment="Center">
                                            <Border.Background>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#FF9E2E" Offset="0"/>
                                                    <GradientStop Color="{DynamicResource AccentColor}" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.45"/>
                                            </Border.Effect>
                                            <materialDesign:PackIcon Kind="CogOutline" Width="24" Height="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                                            <TextBlock Text="Настройки" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                            <TextBlock Text="Персонализация интерфейса, фон и интеграции" Foreground="#88FFFFFF" FontSize="12" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Внешний вид ═══ -->
                                <Border Background="#0AFFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="14" Padding="22,18" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <materialDesign:PackIcon Kind="PaletteOutline" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Внешний вид" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Text="ЦВЕТОВАЯ ТЕМА" Foreground="#66FFFFFF" FontSize="9" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <Border Height="44" CornerRadius="8" Margin="0,0,0,12">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop x:Name="SettingsPreviewStop1" Color="#FF0A0A0A" Offset="0"/>
                                                    <GradientStop x:Name="SettingsPreviewStop2" Color="#FF161623" Offset="0.5"/>
                                                    <GradientStop x:Name="SettingsPreviewStop3" Color="#FF0A0A0A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <UniformGrid Columns="6" Rows="2">
                                            <UniformGrid.Resources>
                                                <Style x:Key="ThemeCard" TargetType="Button">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Margin" Value="3,2"/>
                                                    <Setter Property="Height" Value="56"/>
                                                    <Setter Property="Foreground" Value="#CCFFFFFF"/>
                                                    <Setter Property="FontSize" Value="9"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="#22FFFFFF" BorderThickness="1" RenderTransformOrigin="0.5,0.5">
                                                                    <Border.RenderTransform><ScaleTransform x:Name="Sc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                                                    <TextBlock Text="{TemplateBinding Tag}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                        <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                                                        <Trigger.EnterActions>
                                                                            <BeginStoryboard><Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" To="1.06" Duration="0:0:0.12"/>
                                                                                <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" To="1.06" Duration="0:0:0.12"/>
                                                                            </Storyboard></BeginStoryboard>
                                                                        </Trigger.EnterActions>
                                                                        <Trigger.ExitActions>
                                                                            <BeginStoryboard><Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.15"/>
                                                                                <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.15"/>
                                                                            </Storyboard></BeginStoryboard>
                                                                        </Trigger.ExitActions>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </UniformGrid.Resources>
                                            <Button Click="Dark_Click" Tag="Тёмная" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#0D0D0D" Offset="0"/><GradientStop Color="#1A1A2E" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Blue_Click" Tag="Синяя" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#0A0A1E" Offset="0"/><GradientStop Color="#1A1A4E" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Purple_Click" Tag="Фиолетовая" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#0F051E" Offset="0"/><GradientStop Color="#2D1B69" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Burgundy_Click" Tag="Бордовая" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#1A050D" Offset="0"/><GradientStop Color="#5A0A20" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Green_Click" Tag="Зелёная" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#05140A" Offset="0"/><GradientStop Color="#0E3D1F" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Red_Click" Tag="Красная" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#140505" Offset="0"/><GradientStop Color="#5A1010" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Rose_Click" Tag="Розовая" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#1A050F" Offset="0"/><GradientStop Color="#4E0A2A" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Cyan_Click" Tag="Бирюзовая" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#051414" Offset="0"/><GradientStop Color="#0A3D3D" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Amber_Click" Tag="Янтарная" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#1A1005" Offset="0"/><GradientStop Color="#4E350A" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Mint_Click" Tag="Мятная" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#051A0F" Offset="0"/><GradientStop Color="#0A4E2D" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Lavender_Click" Tag="Лавандовая" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#0F0520" Offset="0"/><GradientStop Color="#3D1A5A" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                            <Button Click="Ocean_Click" Tag="Океан" Style="{StaticResource ThemeCard}">
                                                <Button.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#050A1A" Offset="0"/><GradientStop Color="#0A1A4E" Offset="1"/></LinearGradientBrush></Button.Background>
                                            </Button>
                                        </UniformGrid>
                                        <Button Click="CustomTheme_Click" Cursor="Hand" HorizontalAlignment="Center" Margin="0,8,0,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="#0AFFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="14,7" RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform><ScaleTransform x:Name="Sc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="PaletteOutline" Width="16" Height="16" Foreground="#AAFFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Text="Своя тема" Foreground="#CCFFFFFF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard><Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" To="1.04" Duration="0:0:0.1"/>
                                                                    <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.1"/>
                                                                </Storyboard></BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard><Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                                                    <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                                                </Storyboard></BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Фотообои ═══ -->
                                <Border Background="#0AFFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="14" Padding="22,18" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <materialDesign:PackIcon Kind="ImageOutline" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Фотообои" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Height="140" CornerRadius="10" Background="#0AFFFFFF" ClipToBounds="True" Margin="0,0,0,10" BorderBrush="#15FFFFFF" BorderThickness="1">
                                            <Grid>
                                                <Image x:Name="SettingsBgPreviewImage" Stretch="UniformToFill"/>
                                                <StackPanel x:Name="SettingsBgPreviewEmpty" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <materialDesign:PackIcon Kind="ImageOffOutline" Width="28" Height="28" Foreground="#33FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                                    <TextBlock x:Name="SettingsBgPreviewText" Text="Фон не выбран" Foreground="#55FFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="92"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Размытие" Foreground="#AAFFFFFF" FontSize="12" VerticalAlignment="Center"/>
                                                <Slider x:Name="BgBlurSlider" Grid.Column="1" Minimum="0" Maximum="30" Value="0" Style="{StaticResource ModernSlider}" VerticalAlignment="Center" IsMoveToPointEnabled="True" ValueChanged="BgBlurSlider_ValueChanged"/>
                                                <TextBlock x:Name="BgBlurValue" Grid.Column="2" Text="0px" Foreground="#88FFFFFF" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="92"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Затемнение" Foreground="#AAFFFFFF" FontSize="12" VerticalAlignment="Center"/>
                                                <Slider x:Name="BgDarkenSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="50" Style="{StaticResource ModernSlider}" VerticalAlignment="Center" IsMoveToPointEnabled="True" ValueChanged="BgDarkenSlider_ValueChanged"/>
                                                <TextBlock x:Name="BgDarkenValue" Grid.Column="2" Text="50%" Foreground="#88FFFFFF" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Click="ChooseBackground_Click" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" FontSize="12" Cursor="Hand" Margin="0,0,8,0">
                                                <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="16,8"><StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="ImagePlus" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Выбрать фото" VerticalAlignment="Center"/></StackPanel></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#FF8F1F"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                            </Button>
                                            <Button Click="RemoveBackground_Click" Background="#15FFFFFF" Foreground="#AAFFFFFF" BorderThickness="0" FontSize="12" Cursor="Hand">
                                                <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="16,8"><StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Close" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Убрать фон" VerticalAlignment="Center"/></StackPanel></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Интеграции ═══ -->
                                <Border Background="#0AFFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="14" Padding="22,18" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <materialDesign:PackIcon Kind="PowerPlugOutline" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Интеграции" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Discord Rich Presence" Foreground="#EEFFFFFF" FontSize="13" FontWeight="Medium"/>
                                                <TextBlock Text="Показывать играющий трек в профиле Discord" Foreground="#66FFFFFF" FontSize="11" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <CheckBox x:Name="DiscordToggle" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" IsChecked="True" Checked="DiscordToggle_Changed" Unchecked="DiscordToggle_Changed"/>
                                        </Grid>

                                        <Border Height="1" Background="#10FFFFFF" Margin="0,0,0,12"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Анимации интерфейса" Foreground="#EEFFFFFF" FontSize="13" FontWeight="Medium"/>
                                                <TextBlock Text="Плавные переходы, пульсации, эффекты" Foreground="#66FFFFFF" FontSize="11" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <CheckBox x:Name="AnimationsToggle" Grid.Column="1" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center" IsChecked="True" Checked="AnimationsToggle_Changed" Unchecked="AnimationsToggle_Changed"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Импорт ═══ -->
                                <Border Background="#0AFFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="14" Padding="22,18" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <materialDesign:PackIcon Kind="DatabaseImportOutline" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Импорт данных" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Перенесите свои плейлисты из Spotify через CSV-файл (Exportify, Soundiiz и др.)." Foreground="#77FFFFFF" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                        <Button Click="SpotifyImportButton_Click" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" Foreground="White">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="#15FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="14,9">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="FileDownloadOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource AccentBrush}"/>
                                                            <TextBlock Text="Импорт из CSV" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ Применить ═══ -->
                                <Button x:Name="SettingsApplyBtn" Foreground="White" BorderThickness="0" Click="SettingsApply_Click" FontSize="14" FontWeight="SemiBold" Cursor="Hand" Margin="0,8,0,18" HorizontalAlignment="Stretch" Height="48">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FF9E2E" Offset="0"/>
                                                        <GradientStop Color="{DynamicResource AccentColor}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <materialDesign:PackIcon Kind="Check" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Применить настройки" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.65"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- ═══ Аккаунт ═══ -->
                                <Border Background="#0AFFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="14" Padding="22,18">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <materialDesign:PackIcon Kind="AccountCircleOutline" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Аккаунт" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock x:Name="SettingsAccountStatus" Text="Вы не вошли в SoundCloud" Foreground="#88FFFFFF" FontSize="12" Margin="0,0,0,12"/>

                                        <Button x:Name="LoginButton" Click="LoginButton_Click" BorderThickness="0" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                                Background="{DynamicResource AccentBrush}" Foreground="White" Height="44" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <Grid>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <materialDesign:PackIcon x:Name="LoginIcon" Kind="LoginVariant" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                <TextBlock x:Name="LoginText" Text="Войти в SoundCloud" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ═══ PLAYER ═══ -->
                <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#1AFFFFFF">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#C8141414" Offset="0"/>
                            <GradientStop Color="#C80A0A0A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <!-- Инфо -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="44" Height="44">
                                <Border Width="44" Height="44" CornerRadius="8" Background="#0A0A0A">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="Black" Opacity="0.4"/>
                                    </Border.Effect>
                                </Border>
                                <Border Width="44" Height="44" CornerRadius="8" ClipToBounds="True" Background="#0AFFFFFF">
                                    <Border.OpacityMask>
                                        <VisualBrush Stretch="Fill">
                                            <VisualBrush.Visual>
                                                <Border Background="White" CornerRadius="8" Width="44" Height="44"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Border.OpacityMask>
                                    <Grid>
                                        <TextBlock x:Name="PlayerArtworkPlaceholder" Text="♪" FontSize="18" Foreground="#33FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Image x:Name="PlayerArtwork" Stretch="UniformToFill"/>
                                    </Grid>
                                </Border>
                            </Grid>
                            <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock x:Name="PlayerTitle" Text="Ничего не играет" Foreground="White" FontWeight="Medium" FontSize="13" TextTrimming="CharacterEllipsis" MaxWidth="190"/>
                                <TextBlock x:Name="PlayerArtist" Foreground="#66FFFFFF" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" MaxWidth="190"/>
                            </StackPanel>
                            <Button x:Name="LyricsButton" Width="28" Height="28" Margin="8,0,0,0" Click="LyricsButton_Click" Cursor="Hand" ToolTip="Текст" Visibility="Collapsed" Background="Transparent" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                            <materialDesign:PackIcon Kind="TextBoxOutline" Width="14" Height="14" Foreground="#55FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Контролы -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <Button x:Name="ShuffleButton" Click="ShuffleButton_Click" Style="{StaticResource PlayerIconBtn}" ToolTip="Перемешать">
                                    <materialDesign:PackIcon x:Name="ShuffleIcon" Kind="Shuffle" Width="16" Height="16" Foreground="#88FFFFFF"/>
                                </Button>
                                <Button x:Name="PrevButton" Click="PrevButton_Click" Style="{StaticResource PlayerIconBtn}" Margin="6,0">
                                    <materialDesign:PackIcon Kind="SkipPrevious" Width="20" Height="20" Foreground="#DDFFFFFF"/>
                                </Button>
                                <Button x:Name="PlayPauseButton" Width="40" Height="40" BorderThickness="0" Click="PlayPauseButton_Click" Cursor="Hand" RenderTransformOrigin="0.5,0.5">
                                    <Button.RenderTransform>
                                        <ScaleTransform x:Name="PlayBtnScale" ScaleX="1" ScaleY="1"/>
                                    </Button.RenderTransform>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse Width="40" Height="40" x:Name="PlayEllipse">
                                                    <Ellipse.Fill>
                                                        <RadialGradientBrush Center="0.4,0.3" GradientOrigin="0.4,0.3" RadiusX="0.7" RadiusY="0.7">
                                                            <GradientStop Color="{DynamicResource AccentLightColor}" Offset="0"/>
                                                            <GradientStop Color="{DynamicResource AccentColor}" Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Ellipse.Fill>
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect x:Name="PlayGlow" BlurRadius="14" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.55"/>
                                                    </Ellipse.Effect>
                                                    <Ellipse.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetName="PlayGlow" Storyboard.TargetProperty="Opacity" From="0.55" To="0.3" Duration="0:0:2" AutoReverse="True">
                                                                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard></BeginStoryboard>
                                                        </EventTrigger>
                                                    </Ellipse.Triggers>
                                                </Ellipse>
                                                <Border x:Name="Bd" Width="40" Height="40" CornerRadius="20" Background="Transparent">
                                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Path x:Name="PlayIcon" Data="M6,4 L6,20 L20,12 Z" Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="2,0,0,0"/>
                                                        <StackPanel x:Name="PauseIcon" Orientation="Horizontal" Visibility="Collapsed">
                                                            <Border Width="3" Height="12" Background="White" CornerRadius="1"/>
                                                            <Border Width="3" Height="12" Background="White" CornerRadius="1" Margin="3,0,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button x:Name="NextButton" Click="NextButton_Click" Style="{StaticResource PlayerIconBtn}" Margin="6,0">
                                    <materialDesign:PackIcon Kind="SkipNext" Width="20" Height="20" Foreground="#DDFFFFFF"/>
                                </Button>
                                <Button x:Name="RepeatButton" Click="RepeatButton_Click" Style="{StaticResource PlayerIconBtn}" ToolTip="Повтор">
                                    <materialDesign:PackIcon x:Name="RepeatIcon" Kind="Repeat" Width="16" Height="16" Foreground="#88FFFFFF"/>
                                </Button>
                            </StackPanel>
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="320"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="CurrentTimeText" Text="0:00" Foreground="#55FFFFFF" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider Grid.Column="1" x:Name="ProgressSlider" Minimum="0" Maximum="100" Value="0" Style="{StaticResource ModernSlider}" IsMoveToPointEnabled="True" PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseDown" PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseUp"/>
                                <TextBlock Grid.Column="2" x:Name="TotalTimeText" Text="0:00" Foreground="#55FFFFFF" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- Громкость + EQ -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button x:Name="EqButton" Click="EqButton_Click" Background="Transparent" BorderThickness="0" Width="32" Height="32" Cursor="Hand" Margin="0,0,8,0">
                                <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="16" Width="32" Height="32"><materialDesign:PackIcon Kind="Equalizer" Width="18" Height="18" Foreground="#88FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                            </Button>
                            <materialDesign:PackIcon x:Name="VolumeIcon" Kind="VolumeHigh" Foreground="#88FFFFFF" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0" RenderTransformOrigin="0.5,0.5">
                                <materialDesign:PackIcon.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></materialDesign:PackIcon.RenderTransform>
                            </materialDesign:PackIcon>
                            <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="80" Width="100" Style="{StaticResource ModernSlider}" VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ EQ Popup ═══ -->
            <Popup x:Name="EqPopup" PlacementTarget="{Binding ElementName=EqButton}" Placement="Top" IsOpen="False" AllowsTransparency="True" PopupAnimation="Slide" VerticalOffset="-8">
                <Border Background="#E80E0E0E" CornerRadius="14" Padding="0" BorderThickness="1" BorderBrush="#22FFFFFF" Margin="0,0,0,4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="2" Opacity="0.5" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Hero-заголовок -->
                        <Border CornerRadius="14,14,0,0" Padding="18,14,18,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1AFFFFFF" Offset="0"/>
                                    <GradientStop Color="#0AFFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.35"/>
                                    </Border.Effect>
                                    <materialDesign:PackIcon Kind="Equalizer" Width="16" Height="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Эквалайзер" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="10-полосный" Foreground="#66FFFFFF" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Пресеты -->
                        <Border Padding="14,8,14,6">
                            <StackPanel>
                                <TextBlock Text="ПРЕСЕТЫ" Foreground="#55FFFFFF" FontSize="8" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                <UniformGrid Columns="5" Rows="1" HorizontalAlignment="Center">
                                    <Button Tag="Flat" Click="EqPreset_Flat" Margin="2,0" Cursor="Hand"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="#0AFFFFFF" CornerRadius="6" Padding="0,5" Margin="0,0,2,0"><TextBlock Text="Flat" Foreground="#AAFFFFFF" FontSize="10" HorizontalAlignment="Center" FontWeight="Medium"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                    <Button Tag="Bass" Click="EqPreset_Bass" Margin="2,0" Cursor="Hand"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="#0AFFFFFF" CornerRadius="6" Padding="0,5" Margin="0,0,2,0"><TextBlock Text="Bass" Foreground="#AAFFFFFF" FontSize="10" HorizontalAlignment="Center" FontWeight="Medium"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                    <Button Tag="Treble" Click="EqPreset_Treble" Margin="2,0" Cursor="Hand"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="#0AFFFFFF" CornerRadius="6" Padding="0,5" Margin="0,0,2,0"><TextBlock Text="Treble" Foreground="#AAFFFFFF" FontSize="10" HorizontalAlignment="Center" FontWeight="Medium"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                    <Button Tag="Vocal" Click="EqPreset_Vocal" Margin="2,0" Cursor="Hand"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="#0AFFFFFF" CornerRadius="6" Padding="0,5" Margin="0,0,2,0"><TextBlock Text="Vocal" Foreground="#AAFFFFFF" FontSize="10" HorizontalAlignment="Center" FontWeight="Medium"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                    <Button Tag="Loud" Click="EqPreset_Loud" Margin="2,0" Cursor="Hand"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="#0AFFFFFF" CornerRadius="6" Padding="0,5"><TextBlock Text="Loud" Foreground="#AAFFFFFF" FontSize="10" HorizontalAlignment="Center" FontWeight="Medium"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/><Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- dB шкала -->
                        <Grid Margin="14,0,14,4" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                <TextBlock Text="+12" Foreground="#44FFFFFF" FontSize="7" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,3,0"/>
                                <TextBlock Text="0" Foreground="#55FFFFFF" FontSize="7" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,3,0" FontWeight="Medium"/>
                                <TextBlock Text="-12" Foreground="#44FFFFFF" FontSize="7" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,3,0"/>
                            </StackPanel>
                            <!-- Слайдеры -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                <StackPanel Width="36" HorizontalAlignment="Center" Margin="1,0"><TextBlock x:Name="EqVal0" Text="0" Foreground="{DynamicResource AccentBrush}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,3"/><Slider x:Name="EqSlider0" Minimum="-12" Maximum="12" Value="0" Orientation="Vertical" Height="110" Style="{StaticResource EqVerticalSlider}" ValueChanged="EqSlider_ValueChanged"/><TextBlock Text="32" Foreground="#55FFFFFF" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/></StackPanel>
                                <StackPanel Width="36" HorizontalAlignment="Center" Margin="1,0"><TextBlock x:Name="EqVal1" Text="0" Foreground="{DynamicResource AccentBrush}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,3"/><Slider x:Name="EqSlider1" Minimum="-12" Maximum="12" Value="0" Orientation="Vertical" Height="110" Style="{StaticResource EqVerticalSlider}" ValueChanged="EqSlider_ValueChanged"/><TextBlock Text="64" Foreground="#55FFFFFF" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/></StackPanel>
                                <StackPanel Width="36" HorizontalAlignment="Center" Margin="1,0"><TextBlock x:Name="EqVal2" Text="0" Foreground="{DynamicResource AccentBrush}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,3"/><Slider x:Name="EqSlider2" Minimum="-12" Maximum="12" Value="0" Orientation="Vertical" Height="110" Style="{StaticResource EqVerticalSlider}" ValueChanged="EqSlider_ValueChanged"/><TextBlock Text="125" Foreground="#55FFFFFF" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/></StackPanel>
                                <StackPanel Width="36" HorizontalAlignment="Center" Margin="1,0"><TextBlock x:Name="EqVal3" Text="0" Foreground="{DynamicResource AccentBrush}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,3"/><Slider x:Name="EqSlider3" Minimum="-12" Maximum="12" Value="0" Orientation="Vertical" Height="110" Style="{StaticResource EqVerticalSlider}" ValueChanged="EqSlider_ValueChanged"/><TextBlock Text="250" Foreground="#55FFFFFF" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/></StackPanel>
                                <StackPanel Width="36" HorizontalAlignment="Center" Margin="1,0"><TextBlock x:Name="EqVal4" Text="0" Foreground="{DynamicResource AccentBrush}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,3"/><Slider x:Name="EqSlider4" Minimum="-12" Maximum="12" Value="0" Orientation="Vertical" Height="110" Style="{StaticResource EqVerticalSlider}" ValueChanged="EqSlider_ValueChanged"/><TextBlock Text="500" Foreground="#55FFFFFF" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/></StackPanel>
                                <StackPanel Width="36" HorizontalAlignment="Center" Margin="1,0"><TextBlock x:Name="EqVal5" Text="0" Foreground="{DynamicResource AccentBrush}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,3"/><Slider x:Name="EqSlider5" Minimum="-12" Maximum="12" Value="0" Orientation="Vertical" Height="110" Style="{StaticResource EqVerticalSlider}" ValueChanged="EqSlider_ValueChanged"/><TextBlock Text="1k" Foreground="#55FFFFFF" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/></StackPanel>
                                <StackPanel Width="36" HorizontalAlignment="Center" Margin="1,0"><TextBlock x:Name="EqVal6" Text="0" Foreground="{DynamicResource AccentBrush}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,3"/><Slider x:Name="EqSlider6" Minimum="-12" Maximum="12" Value="0" Orientation="Vertical" Height="110" Style="{StaticResource EqVerticalSlider}" ValueChanged="EqSlider_ValueChanged"/><TextBlock Text="2k" Foreground="#55FFFFFF" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/></StackPanel>
                                <StackPanel Width="36" HorizontalAlignment="Center" Margin="1,0"><TextBlock x:Name="EqVal7" Text="0" Foreground="{DynamicResource AccentBrush}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,3"/><Slider x:Name="EqSlider7" Minimum="-12" Maximum="12" Value="0" Orientation="Vertical" Height="110" Style="{StaticResource EqVerticalSlider}" ValueChanged="EqSlider_ValueChanged"/><TextBlock Text="4k" Foreground="#55FFFFFF" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/></StackPanel>
                                <StackPanel Width="36" HorizontalAlignment="Center" Margin="1,0"><TextBlock x:Name="EqVal8" Text="0" Foreground="{DynamicResource AccentBrush}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,3"/><Slider x:Name="EqSlider8" Minimum="-12" Maximum="12" Value="0" Orientation="Vertical" Height="110" Style="{StaticResource EqVerticalSlider}" ValueChanged="EqSlider_ValueChanged"/><TextBlock Text="8k" Foreground="#55FFFFFF" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/></StackPanel>
                                <StackPanel Width="36" HorizontalAlignment="Center" Margin="1,0"><TextBlock x:Name="EqVal9" Text="0" Foreground="{DynamicResource AccentBrush}" FontSize="9" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,3"/><Slider x:Name="EqSlider9" Minimum="-12" Maximum="12" Value="0" Orientation="Vertical" Height="110" Style="{StaticResource EqVerticalSlider}" ValueChanged="EqSlider_ValueChanged"/><TextBlock Text="16k" Foreground="#55FFFFFF" FontSize="8" HorizontalAlignment="Center" Margin="0,5,0,0"/></StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Кнопка сброса -->
                        <Border Padding="14,0,14,12">
                            <Button Click="EqReset_Click" Cursor="Hand" HorizontalAlignment="Center"><Button.Template><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="#0AFFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16,6"><StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Refresh" Width="12" Height="12" Foreground="#88FFFFFF" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBlock Text="Сбросить" Foreground="#99FFFFFF" FontSize="10" FontWeight="Medium" VerticalAlignment="Center"/></StackPanel></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/><Setter TargetName="Bd" Property="BorderBrush" Value="#25FFFFFF"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template></Button>
                        </Border>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
