<Window x:Class="SoundCloudClient.LyricsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Текст трека" Height="520" Width="440"
        WindowStyle="None"
        Background="#0D0D0D"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/app_icon.png">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0" CornerRadius="12" ResizeBorderThickness="4"
                            CaptionHeight="0" NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>

    <Border ClipToBounds="True" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="#08FFFFFF">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                            VerticalAlignment="Center" Margin="15,0">
                    <Image Source="pack://application:,,,/Resources/app_icon.png"
                           Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Текст трека" Foreground="#CCFFFFFF" FontWeight="SemiBold"
                               VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="36" Height="36" Margin="0,0,6,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#FFAA88" FontSize="13"
                        Click="Close_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Инфо о треке -->
            <StackPanel Grid.Row="1" Margin="20,8,20,4">
                <TextBlock x:Name="TrackTitleText" Foreground="White" FontWeight="SemiBold"
                           FontSize="14" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="TrackArtistText" Foreground="#66FFFFFF" FontSize="11"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Разделитель -->
            <Border Grid.Row="1" VerticalAlignment="Bottom" Height="1"
                    Background="#15FFFFFF" Margin="20,0"/>

            <!-- Текст -->
            <Grid Grid.Row="2">
                <!-- Загрузка -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="Ищем текст..." Foreground="#66FFFFFF" FontSize="13"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Не найдено -->
                <StackPanel x:Name="NotFoundPanel" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="Текст не найден" Foreground="#44FFFFFF" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Попробуйте позже или для другого трека"
                               Foreground="#33FFFFFF" FontSize="10" HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Синхронизированный текст (караоке) -->
                <ScrollViewer x:Name="SyncedScroll" VerticalScrollBarVisibility="Hidden"
                              Margin="20,12,20,16" Visibility="Collapsed"
                              CanContentScroll="False" PanningMode="VerticalOnly">
                    <StackPanel x:Name="SyncedLinesPanel"/>
                </ScrollViewer>

                <!-- Обычный текст (без синхронизации) -->
                <ScrollViewer x:Name="PlainScroll" VerticalScrollBarVisibility="Auto"
                              Margin="20,12,20,16" Visibility="Collapsed">
                    <TextBlock x:Name="LyricsText" Foreground="#CCFFFFFF" FontSize="13"
                               LineHeight="22" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
