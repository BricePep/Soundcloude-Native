<Window x:Class="SoundCloudClient.WebView2LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Вход в SoundCloud" Height="700" Width="900"
        WindowStyle="None"
        Background="#0D0D0D"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/app_icon.png">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome GlassFrameThickness="0" CornerRadius="12" ResizeBorderThickness="4"
                            CaptionHeight="0" NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>

    <Border ClipToBounds="True" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  Background="#08FFFFFF">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                            VerticalAlignment="Center" Margin="15,0">
                    <Image Source="pack://application:,,,/Resources/app_icon.png"
                           Width="18" Height="18" Margin="0,0,6,0" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Вход в SoundCloud" Foreground="#CCFFFFFF" FontWeight="SemiBold"
                               VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,6,0">
                    <Button Content="─" Foreground="#99FFFFFF" FontSize="13"
                            Click="Minimize_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                        Width="36" Height="36">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="✕" Foreground="#FFAA88"
                            Click="Close_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                        Width="36" Height="36">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- WebView2 -->
            <Border Grid.Row="1" Margin="10,0,10,10" CornerRadius="10" ClipToBounds="True"
                    Background="#12FFFFFF">
                <wv2:WebView2 x:Name="WebView"/>
            </Border>
        </Grid>
    </Border>
</Window>
