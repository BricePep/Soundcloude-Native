<Window x:Class="SoundCloudClient.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SC Native" Height="360" Width="480"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Коробка — тень под коробкой -->
        <DropShadowEffect x:Key="BoxShadow" ShadowDepth="8" Direction="270"
                          Opacity="0.5" BlurRadius="16" Color="#000000"/>

        <!-- Диск — свечение -->
        <DropShadowEffect x:Key="DiscGlow" ShadowDepth="0" Direction="0"
                          Opacity="0.6" BlurRadius="20" Color="#CC7B3A"/>
    </Window.Resources>

    <Border CornerRadius="16" Background="#0D0D0D" BorderBrush="#222222" BorderThickness="1"
            Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ Центральная область — коробка + диск ═══ -->
            <Grid Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                  Margin="0,10,0,0">

                <!-- Тень под коробкой (эллипс) -->
                <Ellipse x:Name="BoxShadowEllipse" Width="120" Height="18"
                         Fill="#15000000" VerticalAlignment="Bottom"
                         Margin="0,0,0,30" Opacity="0"/>

                <!-- Коробка (пакет) -->
                <Grid x:Name="BoxGroup" VerticalAlignment="Bottom" Margin="0,0,0,30" Opacity="0">
                    <!-- Передняя грань коробки -->
                    <Border Width="120" Height="80" CornerRadius="4"
                            Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1"
                            Effect="{StaticResource BoxShadow}">
                        <Grid>
                            <!-- Лого на коробке -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="SC" FontSize="22" FontWeight="Bold"
                                           Foreground="#CC7B3A" HorizontalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                                <TextBlock Text="N A T I V E" FontSize="8" FontWeight="SemiBold"
                                           Foreground="#666666" HorizontalAlignment="Center"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Крышка коробки (верхняя грань — параллелограмм) -->
                    <Polygon x:Name="BoxLid" Points="0,0 120,0 140,-18 20,-18"
                             Fill="#252525" Stroke="#333333" StrokeThickness="1"
                             VerticalAlignment="Top" Margin="0,-18,0,0"
                             HorizontalAlignment="Center" Width="140"
                             RenderTransformOrigin="0.5,1">
                        <Polygon.RenderTransform>
                            <RotateTransform x:Name="LidRotate" Angle="0"/>
                        </Polygon.RenderTransform>
                    </Polygon>

                    <!-- Правая боковая грань -->
                    <Polygon Points="120,0 140,-18 140,62 120,80"
                             Fill="#161616" Stroke="#333333" StrokeThickness="1"
                             HorizontalAlignment="Right" Margin="0,-18,0,0"/>
                </Grid>

                <!-- Диск (виниловая пластинка) -->
                <Grid x:Name="DiscGroup" VerticalAlignment="Bottom"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,110" Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="DiscTranslate" Y="60"/>
                    </Grid.RenderTransform>

                    <!-- Внешний круг диска (винил) -->
                    <Ellipse Width="90" Height="90" Fill="#111111" Stroke="#333333" StrokeThickness="1.5">
                        <Ellipse.Effect>
                            <DropShadowEffect ShadowDepth="4" Direction="270"
                                              Opacity="0.4" BlurRadius="12" Color="#000000"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <!-- Блики на виниле (концентрические кольца) -->
                    <Ellipse Width="78" Height="78" Stroke="#1A1A1A" StrokeThickness="0.5"
                             Fill="Transparent"/>
                    <Ellipse Width="66" Height="66" Stroke="#1A1A1A" StrokeThickness="0.5"
                             Fill="Transparent"/>
                    <Ellipse Width="54" Height="54" Stroke="#1A1A1A" StrokeThickness="0.5"
                             Fill="Transparent"/>

                    <!-- Лейбл диска (центр) -->
                    <Ellipse Width="36" Height="36" Fill="#CC7B3A" Stroke="#E08F4E" StrokeThickness="0.5">
                        <Ellipse.Effect>
                            <DropShadowEffect ShadowDepth="0" Direction="0"
                                              Opacity="0.3" BlurRadius="8" Color="#CC7B3A"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <!-- Иконка на лейбле -->
                    <Image Source="pack://application:,,,/Resources/app_icon.png"
                           Width="24" Height="24" RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- Дырка в центре -->
                    <Ellipse Width="6" Height="6" Fill="#0D0D0D"/>

                    <!-- Блик на диске (вращающийся) -->
                    <Ellipse x:Name="DiscHighlight" Width="90" Height="90"
                             Fill="Transparent" Stroke="#15FFFFFF" StrokeThickness="0.3"
                             StrokeDashArray="2 4" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="HighlightRotate" Angle="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>
            </Grid>

            <!-- ═══ Нижняя часть — текст + прогресс ═══ -->
            <StackPanel Grid.Row="1" VerticalAlignment="Bottom"
                        HorizontalAlignment="Center" Margin="0,0,0,30">
                <!-- Название приложения -->
                <TextBlock x:Name="AppNameText" Text="SoundCloud Native"
                           FontSize="18" FontWeight="Bold" Foreground="#E0E0E0"
                           HorizontalAlignment="Center" Margin="0,0,0,4"
                           Opacity="0"/>
                <!-- Статус загрузки -->
                <TextBlock x:Name="StatusText" Text="Загрузка..."
                           FontSize="11" Foreground="#80FFFFFF"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           Opacity="0"/>
                <!-- Прогресс-бар -->
                <ProgressBar x:Name="LoadingProgress" Width="200" Height="3"
                             Minimum="0" Maximum="100" Value="0"
                             Foreground="#CC7B3A" Background="#252525"
                             Opacity="0">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid>
                                <Border x:Name="PART_Track" Background="{TemplateBinding Background}"
                                        CornerRadius="1.5"/>
                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                        CornerRadius="1.5" HorizontalAlignment="Left"/>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
            </StackPanel>
        </Grid>
    </Border>
</Window>
