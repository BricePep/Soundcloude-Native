<Window x:Class="SCNativeInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SC Native — Установка" Height="520" Width="680"
        WindowStyle="None"
        Background="#0D0D0D"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/app_icon.png"
        Closing="Window_Closing">

    <Window.Resources>
        <ResourceDictionary>
            <Storyboard x:Key="FadeIn">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            </Storyboard>
            <Storyboard x:Key="SlideIn">
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                <ThicknessAnimation Storyboard.TargetProperty="Margin" From="30,0,-30,0" To="0" Duration="0:0:0.25">
                    <ThicknessAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </ThicknessAnimation.EasingFunction>
                </ThicknessAnimation>
            </Storyboard>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12" Background="#0D0D0D" BorderBrush="#222222" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>      <!-- Content -->
                <RowDefinition Height="Auto"/>   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ═══ Title Bar ═══ -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" Background="#111111"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Height="42">
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Resources/app_icon.png"
                               Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="SC Native" FontSize="14" Foreground="#E0E0E0"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Установка" FontSize="12" Foreground="#666666"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="CloseButton" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="40" Height="42" Click="CloseButton_Click" Cursor="Hand"
                            BorderThickness="0" Background="Transparent">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="0,12,0,0">
                                    <TextBlock Text="✕" Foreground="#888888" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                        <Setter TargetName="Bd" Property="TextBlock.Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ Step Indicator ═══ -->
            <StackPanel Grid.Row="0" Margin="0,42,0,0" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Top">
                <!-- Шаги генерируются в коде -->
                <ItemsControl x:Name="StepIndicator" Margin="0,12,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>

            <!-- ═══ Content Area ═══ -->
            <Grid Grid.Row="1" Margin="0,20,0,0">
                <!-- Step 1: Welcome -->
                <Grid x:Name="StepWelcome" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="40,0">
                        <TextBlock Text="🎵" FontSize="48" HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <TextBlock Text="SoundCloud Native" FontSize="28" FontWeight="Bold"
                                   Foreground="#E0E0E0" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Кастомный десктоп-клиент для SoundCloud" FontSize="14"
                                   Foreground="#80FFFFFF" HorizontalAlignment="Center"
                                   Margin="0,0,0,32"/>
                        <Border Background="#1A1A1A" CornerRadius="10" Padding="24,20"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Что будет установлено:" Foreground="#CC7B3A"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Foreground="#B0B0B0" FontSize="12" LineHeight="22"
                                           Text="• Плеер с эквалайзером и караоке-текстами&#x0a;• Интеграция с SoundCloud API&#x0a;• Локальная библиотека (лайки, плейлисты)&#x0a;• AI-рекомендации на основе ваших жанров"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Step 2: Install Path -->
                <Grid x:Name="StepPath" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" Margin="40,0">
                        <TextBlock Text="Путь установки" FontSize="22" FontWeight="Bold"
                                   Foreground="#E0E0E0" Margin="0,0,0,8"/>
                        <TextBlock Text="Выберите папку для установки SC Native"
                                   Foreground="#80FFFFFF" FontSize="13" Margin="0,0,0,24"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PathBox" Grid.Column="0" Style="{StaticResource PathTextBox}"
                                     Text="C:\Program Files\SC Native"/>
                            <Button x:Name="BrowseButton" Grid.Column="1" Content="Обзор"
                                    Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                                    Click="BrowseButton_Click"/>
                        </Grid>
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="16,12"
                                Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Дополнительные опции" Foreground="#CC7B3A"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <CheckBox x:Name="CheckDesktopShortcut" Content="Ярлык на рабочем столе"
                                          Style="{StaticResource InstallerCheckBox}" IsChecked="True"
                                          Margin="0,0,0,8"/>
                                <CheckBox x:Name="CheckStartMenu" Content="Ярлык в меню «Пуск»"
                                          Style="{StaticResource InstallerCheckBox}" IsChecked="True"
                                          Margin="0,0,0,8"/>
                                <CheckBox x:Name="CheckAutoStart" Content="Запуск при входе в систему"
                                          Style="{StaticResource InstallerCheckBox}" IsChecked="False"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Step 3: Installing -->
                <Grid x:Name="StepInstalling" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="40,0">
                        <TextBlock x:Name="InstallTitle" Text="Установка..." FontSize="22"
                                   FontWeight="Bold" Foreground="#E0E0E0"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="InstallStatus" Text="Подготовка..."
                                   Foreground="#80FFFFFF" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,0,0,24"/>
                        <ProgressBar x:Name="InstallProgress"
                                     Style="{StaticResource InstallerProgressBar}"
                                     Width="400" Minimum="0" Maximum="100" Value="0"/>
                        <TextBlock x:Name="InstallPercent" Text="0%"
                                   Foreground="#CC7B3A" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Step 4: Complete -->
                <Grid x:Name="StepComplete" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="40,0">
                        <TextBlock Text="✓" FontSize="48" Foreground="#CC7B3A"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Установка завершена!" FontSize="24" FontWeight="Bold"
                                   Foreground="#E0E0E0" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="SC Native готов к запуску"
                                   Foreground="#80FFFFFF" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,0,0,32"/>
                        <CheckBox x:Name="CheckLaunchApp" Content="Запустить SC Native"
                                  Style="{StaticResource InstallerCheckBox}" IsChecked="True"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ═══ Footer ═══ -->
            <Border Grid.Row="2" Background="#111111" CornerRadius="0,0,12,12" Padding="24,14">
                <Grid>
                    <Button x:Name="BackButton" Content="Назад"
                            Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Left"
                            Click="BackButton_Click" Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CancelButton" Content="Отмена"
                                Style="{StaticResource GhostButton}"
                                Click="CancelButton_Click" Margin="0,0,8,0"/>
                        <Button x:Name="NextButton" Content="Далее"
                                Style="{StaticResource AccentButton}"
                                Click="NextButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
